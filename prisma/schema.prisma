// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

 
 

// --- ENUMS ---
enum UserRole {
  Admin
  Project_Manager @map("Project Manager")
  Team_Member     @map("Team Member")
}

enum ProjectStatus {
  Active
  Completed
  On_Hold       @map("On Hold")
}

enum TaskPriority {
  Low
  Medium
  High
}

enum TaskStatus {
  Todo
  In_Progress  @map("In Progress")
  Completed
}

// --- MODELS ---

model User {
  id            String          @id @default(uuid())
  name          String          @db.VarChar(100)
  email         String          @unique @db.VarChar(150)
  passwordHash  String          @map("password_hash") @db.VarChar(255)
  role          UserRole        @default(Team_Member)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  
  // Relations
  createdProjects Project[]     @relation("ProjectCreator")
  projects        ProjectMember[]
  assignedTasks   Task[]          @relation("TaskAssignee")
  comments        Comment[]
  activityLogs    ActivityLog[]

  @@map("users")
  @@index([name]) // Optimize member-wise search
}

model Project {
  id          String        @id @default(uuid())
  name        String        @db.VarChar(150)
  description String?       @db.Text
  deadline    DateTime      @db.Date
  status      ProjectStatus @default(Active)
  createdBy   String?       @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // Relations
  creator     User?         @relation("ProjectCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  members     ProjectMember[]
  tasks       Task[]
  activityLogs ActivityLog[]

  @@map("projects")
  @@index([name])
  @@index([status])
}

// Explicit Many-to-Many Table for Projects and Members
model ProjectMember {
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  // Relations
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@map("project_members")
}

model Task {
  id               String       @id @default(uuid())
  projectId        String       @map("project_id")
  title            String       @db.VarChar(200)
  description      String?      @db.Text
  assignedMemberId String?      @map("assigned_member_id")
  dueDate          DateTime     @map("due_date") @db.Date
  priority         TaskPriority @default(Medium)
  status           TaskStatus   @default(Todo)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  // Relations
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee         User?        @relation("TaskAssignee", fields: [assignedMemberId], references: [id], onDelete: SetNull)
  comments         Comment[]

  @@map("tasks")
  // Requirement 4: Unique task title inside same project
  @@unique([projectId, title], name: "project_task_title_unique")
  // Performance Indices for Complex Filtering & Sorts
  @@index([projectId, status, priority, dueDate(sort: Desc)])
}

model Comment {
  id          String   @id @default(uuid())
  taskId      String   @map("task_id")
  userId      String   @map("user_id")
  commentText String   @map("comment_text") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model ActivityLog {
  id                  String   @id @default(uuid())
  projectId           String?  @map("project_id")
  userId              String?  @map("user_id")
  activityDescription String   @map("activity_description") @db.Text
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  project             Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("activity_log")
}